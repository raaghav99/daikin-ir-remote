<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daikin AC Remote"
            android:textColor="#E94560"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="STATUS" android:textColor="#888888" android:textSize="10sp" />
                    <TextView android:id="@+id/tvPowerStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="OFF" android:textColor="#E94560"
                        android:textSize="22sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TEMP" android:textColor="#888888" android:textSize="10sp" />
                    <TextView android:id="@+id/tvTemperature"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="24°C" android:textColor="#00D4FF"
                        android:textSize="22sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MODE" android:textColor="#888888" android:textSize="10sp" />
                    <TextView android:id="@+id/tvMode"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Cool" android:textColor="#00FF88"
                        android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="FAN" android:textColor="#888888" android:textSize="10sp" />
                    <TextView android:id="@+id/tvFanSpeed"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Auto" android:textColor="#FFD700"
                        android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Find Brand Button -->
        <Button
            android:id="@+id/btnScanBrand"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="FIND MY BRAND (Brute Force)"
            android:textSize="13sp"
            android:backgroundTint="#0F3460"
            android:textColor="#00D4FF"
            android:layout_marginBottom="12dp" />

        <!-- Power Button -->
        <Button
            android:id="@+id/btnPower"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="POWER ON"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#E94560"
            android:layout_marginBottom="12dp" />

        <!-- Temperature Controls -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="TEMPERATURE" android:textColor="#888888" android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <Button android:id="@+id/btnTempDown"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                android:text="- Temp" android:backgroundTint="#16213E"
                android:textColor="#00D4FF" android:layout_marginEnd="4dp" />
            <Button android:id="@+id/btnTempUp"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                android:text="+ Temp" android:backgroundTint="#16213E"
                android:textColor="#00D4FF" android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Mode Buttons -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="MODE" android:textColor="#888888" android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <Button android:id="@+id/btnModeCool" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="Cool" android:backgroundTint="#0F3460"
                android:textColor="#00D4FF" android:textSize="12sp"
                android:layout_marginEnd="2dp" />
            <Button android:id="@+id/btnModeHeat" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="Heat" android:backgroundTint="#0F3460"
                android:textColor="#FF6B35" android:textSize="12sp"
                android:layout_marginEnd="2dp" />
            <Button android:id="@+id/btnModeDry" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="Dry" android:backgroundTint="#0F3460"
                android:textColor="#00FF88" android:textSize="12sp"
                android:layout_marginEnd="2dp" />
            <Button android:id="@+id/btnModeFan" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="Fan" android:backgroundTint="#0F3460"
                android:textColor="#FFD700" android:textSize="12sp"
                android:layout_marginEnd="2dp" />
            <Button android:id="@+id/btnModeAuto" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="Auto" android:backgroundTint="#0F3460"
                android:textColor="#FFFFFF" android:textSize="12sp" />
        </LinearLayout>

        <!-- Fan Speed -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="FAN SPEED" android:textColor="#888888" android:textSize="12sp"
            android:layout_marginTop="8dp" android:layout_marginBottom="6dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btnFanAuto" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="Auto" android:backgroundTint="#0F3460"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:layout_marginEnd="2dp" />
            <Button android:id="@+id/btnFanSilent" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="Silent" android:backgroundTint="#0F3460"
                android:textColor="#AAAAAA" android:textSize="11sp"
                android:layout_marginEnd="2dp" />
            <Button android:id="@+id/btnFanLow" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="Low" android:backgroundTint="#0F3460"
                android:textColor="#00FF88" android:textSize="11sp"
                android:layout_marginEnd="2dp" />
            <Button android:id="@+id/btnFanMed" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="Med" android:backgroundTint="#0F3460"
                android:textColor="#FFD700" android:textSize="11sp"
                android:layout_marginEnd="2dp" />
            <Button android:id="@+id/btnFanHigh" android:layout_width="0dp"
                android:layout_height="48dp" android:layout_weight="1"
                android:text="High" android:backgroundTint="#0F3460"
                android:textColor="#FF6B35" android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
